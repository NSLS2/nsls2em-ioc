
record(longout, "$(PriSys){$(PSC)}$(Reg)-Sp") {
  field(DESC, "$(Reg)-$(Name)")
  field(VAL, "$(Val)")
  field(DTYP, "PSC Single I32")
  field(OUT , "@CmdPort_$(PSC) 80 $(RegOffset)")  
  field(FLNK, "$(PriSys){$(PSC)}GoRegSingleWrite")
  info(autosaveFields_pass0, "VAL")
  info(SYNC, "ProcOnConn")
}

record(longin, "$(PriSys){$(PSC)}$(Reg)-I")
{
  field(DESC, "$(Reg)-$(Name)")
  field(DTYP, "PSC Reg")
  field(INP , "@RxPort_$(PSC) 82 $(RegOffset)")
  field(SCAN, "I/O Intr")
}
